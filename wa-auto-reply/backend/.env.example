MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/wa_auto_reply?retryWrites=true&w=majority&appName=Cluster0
CLIENT_ID=your_google_client_id
CLIENT_SECRET=your_google_client_secret
OPENROUTER_API_KEY=your_openrouter_api_key
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=30d
PORT=5001
CLIENT_URL=http://localhost:3001
MODEL_NAME=openai/gpt-oss-120b:free
BACKEND_URL=http://localhost:5001
CALLBACK_URL=http://localhost:5001/api/auth/google/callback
WHATSAPP_AUTH_PATH=./.baileys_auth
# disk = local files (most reliable locally). mongo = MongoDB (for cloud deploy without disk).
WHATSAPP_AUTH_STORE=disk
# Set WHATSAPP_AUTH_REPAIR=true once to force re-import disk session into MongoDB.
WHATSAPP_AUTH_REPAIR=false
NODE_ENV=development
