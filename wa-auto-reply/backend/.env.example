# Standalone WA Auto Reply — use a SEPARATE database from the main WA Sender app
MONGODB_URI=mongodb://localhost:27017/wa_auto_reply

# Server (default 5001 — main app uses 5000)
PORT=5001
CLIENT_URL=http://localhost:3001

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=30d

# Google OAuth (optional)
CLIENT_ID=your_google_client_id
CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# AI (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key
MODEL_NAME=openai/gpt-4o-mini

# WhatsApp session storage (optional — defaults to backend/.baileys_auth)
# WHATSAPP_AUTH_PATH=./.baileys_auth
